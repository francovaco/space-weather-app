# ============================================================
# Space Weather App — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in values as needed.
# .env.local is gitignored by default in Next.js.

# --- App ---
NEXT_PUBLIC_APP_NAME="GOES-19 Space Weather"
NEXT_PUBLIC_APP_VERSION="0.1.0"

# --- GOES / NOAA Data Sources ---
# Base URL for GOES-19 ABI imagery (STAR/NESDIS CDN)
NEXT_PUBLIC_GOES19_CDN="https://cdn.star.nesdis.noaa.gov/GOES19/ABI"

# Base URL for SWPC JSON data services
NEXT_PUBLIC_SWPC_SERVICES="https://services.swpc.noaa.gov"

# SWPC website (for images/animations not available via services)
NEXT_PUBLIC_SWPC_WWW="https://www.swpc.noaa.gov"

# NOAA OSPO status page
NEXT_PUBLIC_OSPO_STATUS="https://www.ospo.noaa.gov"

# STAR imagery viewer base
NEXT_PUBLIC_STAR_BASE="https://www.star.nesdis.noaa.gov"

# NOAA NOWCOAST lightning base
NEXT_PUBLIC_NOAA_NOWCOAST="https://nowcoast.noaa.gov"

# --- Weather & NASA Sources ---
# Open-Meteo API (used for local weather and models)
NEXT_PUBLIC_OPEN_METEO_API="https://api.open-meteo.com/v1"

# NASA POWER API (used for satellite precipitation)
NEXT_PUBLIC_NASA_POWER_API="https://power.larc.nasa.gov/api"

# Reverse Geocoding service
NEXT_PUBLIC_BIGDATACLOUD_API="https://api.bigdatacloud.net/data/reverse-geocode-client"

# --- Feature Flags ---
# Set to "true" to enable experimental features
NEXT_PUBLIC_ENABLE_AURORA_MAP="true"
NEXT_PUBLIC_ENABLE_SOLAR_WIND="true"
NEXT_PUBLIC_ENABLE_CORONAGRAPH="true"

# --- Cache TTL (seconds) ---
# How long to cache proxy responses server-side
CACHE_TTL_IMAGERY=600       # 10 minutes — ABI channel images
CACHE_TTL_MAGNETOMETER=60   # 1 minute
CACHE_TTL_XRAY=60           # 1 minute
CACHE_TTL_PARTICLES=300     # 5 minutes — electron/proton flux
CACHE_TTL_AURORA=300        # 5 minutes
CACHE_TTL_CORONAGRAPH=600   # 10 minutes
CACHE_TTL_SOLAR_WIND=60     # 1 minute
