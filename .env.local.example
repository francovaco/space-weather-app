# ============================================================
# GOES-19 Space Weather App — Variables de Entorno
# ============================================================
# Copia este archivo a .env.local y completa los valores.
# .env.local está en .gitignore — nunca lo subas al repositorio.
# ============================================================

# --- Identidad de la aplicación ---
# Nombre y versión mostrados en la UI y metadatos
NEXT_PUBLIC_APP_NAME="GOES-19 Space Weather"
NEXT_PUBLIC_APP_VERSION="0.1.0"

# --- Fuentes de imágenes GOES-19 ---
# CDN de STAR/NESDIS para imágenes ABI (bandas espectrales y productos RGB)
# Usado en: src/lib/goes-imagery.ts
NEXT_PUBLIC_GOES19_CDN="https://cdn.star.nesdis.noaa.gov/GOES19/ABI"

# Visor de imágenes STAR (enlaces externos y animaciones)
# Usado en: src/lib/goes-imagery.ts
NEXT_PUBLIC_STAR_BASE="https://www.star.nesdis.noaa.gov"

# --- Fuentes de datos NOAA/SWPC ---
# API de datos en tiempo real del Space Weather Prediction Center
# Usado en: src/lib/swpc-api.ts — flujo de partículas, magnetómetro, rayos X, Kp, etc.
NEXT_PUBLIC_SWPC_SERVICES="https://services.swpc.noaa.gov"

# Sitio web SWPC (imágenes y animaciones de modelos: aurora, viento solar, coronógrafo)
NEXT_PUBLIC_SWPC_WWW="https://www.swpc.noaa.gov"

# NOAA OSPO — fuente del estado operacional de la constelación GOES
# Usado en: src/app/api/goes/status/route.ts
NEXT_PUBLIC_OSPO_STATUS="https://www.ospo.noaa.gov"

# NOAA NowCOAST — base para capas WMS de rayos GLM y otros productos en tiempo real
NEXT_PUBLIC_NOAA_NOWCOAST="https://nowcoast.noaa.gov"

# --- Fuentes meteorológicas y precipitación ---
# Open-Meteo: datos meteorológicos locales (temperatura, viento, humedad)
# Usado en: src/app/api/smn/weather/route.ts
NEXT_PUBLIC_OPEN_METEO_API="https://api.open-meteo.com/v1"

# NASA POWER: precipitación diaria histórica por coordenadas (reanálisis MERRA-2)
# Usado en: src/app/api/nasa/precipitation/route.ts
NEXT_PUBLIC_NASA_POWER_API="https://power.larc.nasa.gov/api"

# BigDataCloud: geocodificación inversa (lat/lon → nombre de ciudad) sin API key
# Usado en: src/app/api/smn/weather/route.ts
NEXT_PUBLIC_BIGDATACLOUD_API="https://api.bigdatacloud.net/data/reverse-geocode-client"

# --- Feature Flags ---
# Activa o desactiva secciones experimentales de la UI
NEXT_PUBLIC_ENABLE_AURORA_MAP="true"
NEXT_PUBLIC_ENABLE_SOLAR_WIND="true"
NEXT_PUBLIC_ENABLE_CORONAGRAPH="true"

# --- NASA API Key ---
# Requerida para el Monitor de Anomalías Satelitales (NASA DONKI notifications).
# Sin esta key se usa DEMO_KEY, con límite de 30 requests/hora y 50/día.
# Obtén tu key gratuita (1.000 req/hora) en: https://api.nasa.gov/
NASA_API_KEY="TU_API_KEY_AQUI"

# --- Sentry (monitoreo de errores) ---
# Crea un proyecto en https://sentry.io → Settings → Client Keys → DSN
NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
SENTRY_AUTH_TOKEN="sntrys_..."  # Para upload de sourcemaps en CI/CD (opcional)

# --- Web Push / VAPID ---
# Genera tus propias claves con: node -e "require('web-push').generateVAPIDKeys()"
# O bien: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="TU_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="TU_VAPID_PRIVATE_KEY"
VAPID_EMAIL="tu@email.com"
